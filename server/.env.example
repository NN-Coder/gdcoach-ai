# GDCoach AI — Server environment variables
# Copy this file to `.env` and fill in your values.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Google AI Studio API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-google-ai-studio-key-here

# ── Optional ──────────────────────────────────────────────────────────────────

# Gemini model to use. gemini-1.5-flash is fast and free-tier friendly.
# Other options: gemini-1.5-pro, gemini-2.0-flash-exp
GEMINI_MODEL=gemini-1.5-flash

# Maximum number of output tokens. Keep low to enforce brevity.
MAX_TOKENS=300
